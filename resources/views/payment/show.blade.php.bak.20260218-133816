    function insertSubscriptionCard(cardHtml) {
        const rows = document.querySelector('.service-block__rows');
        if (!rows || !cardHtml) return;

        const temp = document.createElement('div');
        temp.innerHTML = cardHtml.trim();
        const card = temp.firstElementChild;
        if (!card) return;

        const col = document.createElement('div');
        col.className = 'service-block__col';
        col.appendChild(card);

        const lastRow = rows.querySelector('.service-block__row:last-child');
        if (lastRow) {
            const empty = lastRow.querySelector('.service-block__col--empty');
            if (empty) {
                empty.replaceWith(col);
                return;
            }
        }

        const row = document.createElement('div');
        row.className = 'service-block__row';
        row.appendChild(col);

        const emptyCol = document.createElement('div');
        emptyCol.className = 'service-block__col service-block__col--empty';
        row.appendChild(emptyCol);

        rows.appendChild(row);
    }

    function replaceSubscriptionCard(cardHtml, subId, preferredCard) {
        if (!cardHtml) return;
        const temp = document.createElement('div');
        temp.innerHTML = cardHtml.trim();
        const newCard = temp.firstElementChild;
        if (!newCard) return;

        const id = subId || newCard.dataset.subId;
        if (!id) return;

        if (preferredCard && preferredCard.dataset && preferredCard.dataset.subId === String(id)) {
            preferredCard.replaceWith(newCard);
            return newCard;
        }

        const current = document.querySelector(`.service-block__card[data-sub-id="${id}"]`);
        if (current) {
            current.replaceWith(newCard);
            return newCard;
        }
    }

