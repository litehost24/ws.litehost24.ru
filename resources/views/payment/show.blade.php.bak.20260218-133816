<script>
    document.addEventListener('DOMContentLoaded', function () {
        const root = document.getElementById('support-chat-widget');
        if (!root) {
            return;
        }

        const openBtn = document.getElementById('support-chat-open');
        const panel = document.getElementById('support-chat-panel');
        const closeTopBtn = document.getElementById('support-chat-close-top');
        const list = document.getElementById('support-chat-list');
        const form = document.getElementById('support-chat-form');
        const input = document.getElementById('support-chat-input');
        const badge = document.getElementById('support-chat-unread-badge');
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';

        const endpoints = {
            chat: root.dataset.chatEndpoint,
            messages: root.dataset.messagesEndpoint,
            send: root.dataset.sendEndpoint,
            read: root.dataset.readEndpoint,
            unread: root.dataset.unreadEndpoint,
        };

        let isOpen = false;
        let lastMessageId = 0;
        let pollTimer = null;
        let chatStatus = 'open';
        let closedDraftMode = false;

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function formatTime(value) {
            if (!value) {
                return '';
            }
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) {
                return '';
            }
            return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        async function fetchJson(url, options) {
            const response = await fetch(url, options || {});
            const data = await response.json().catch(function () { return {}; });
            if (!response.ok) {
                throw new Error(data.message || 'Ошибка запроса');
            }
            return data;
        }

        function handleClosedState() {
            chatStatus = 'closed';
            lastMessageId = 0;
            setUnread(0);

            // Auto-collapse only when user is not actively reopening chat to send a new message.
            if (!closedDraftMode) {
                list.innerHTML = '';
                closePanel();
            }
        }

        function setUnread(count) {
            const safe = Number(count || 0);
            if (!safe) {
                badge.hidden = true;
                return;
            }
            badge.hidden = false;
            badge.textContent = String(safe);
        }

        function appendMessages(messages) {
            if (!Array.isArray(messages) || !messages.length) {
                return;
            }

            const nearBottom = list.scrollTop + list.clientHeight >= list.scrollHeight - 50;

            messages.forEach(function (msg) {
                const item = document.createElement('div');
                item.className = 'support-chat-msg ' + (msg.sender_role === 'user' ? 'support-chat-msg--mine' : '');
                item.innerHTML = `
                    <div class="support-chat-msg__meta">${escapeHtml(msg.sender_name || msg.sender_role)} · ${formatTime(msg.created_at)}</div>
                    <div>${escapeHtml(msg.body)}</div>
                `;
                list.appendChild(item);
                lastMessageId = Math.max(lastMessageId, Number(msg.id || 0));
            });

            if (nearBottom) {
                list.scrollTop = list.scrollHeight;
            }
        }

        async function refreshUnread() {
            try {
                const data = await fetchJson(endpoints.chat, {
                    headers: { 'Accept': 'application/json' },
                });

                chatStatus = data.chat?.status || 'open';
                if (chatStatus === 'closed') {
                    handleClosedState();
                    return;
                }

                setUnread(data.unread_count || 0);
            } catch (e) {
                console.error(e);
            }
        }

        async function loadMessages(markAsRead) {
            try {
                const data = await fetchJson(endpoints.messages + '?after_id=' + encodeURIComponent(lastMessageId), {
                    headers: { 'Accept': 'application/json' },
                });

                chatStatus = data.chat_status || chatStatus || 'open';
                if (chatStatus === 'closed') {
                    handleClosedState();
                    return;
                }

                appendMessages(data.messages || []);

                if (markAsRead) {
                    await fetchJson(endpoints.read, {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'X-CSRF-TOKEN': csrf,
                        },
                    });
                    setUnread(0);
                }
            } catch (e) {
                console.error(e);
            }
        }

        function openPanel() {
            isOpen = true;
            openBtn.hidden = true;
            panel.hidden = false;

            if (chatStatus === 'closed') {
                closedDraftMode = true;
                list.innerHTML = '<div class="support-chat-msg" style="max-width:100%;">Диалог завершён. Напишите сообщение, чтобы начать новый.</div>';
                input.placeholder = 'Напишите, чтобы начать новый диалог';
                input.focus();
                return;
            }

            input.placeholder = 'Напишите, чем помочь';
            loadMessages(true);
            input.focus();
        }

        function closePanel() {
            isOpen = false;
            panel.hidden = true;
            openBtn.hidden = false;
            input.placeholder = 'Напишите, чем помочь';
            closedDraftMode = false;
        }

        openBtn.addEventListener('click', openPanel);
        closeTopBtn.addEventListener('click', closePanel);

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            const text = input.value.trim();
            if (!text) {
                return;
            }

            if (chatStatus === 'closed') {
                list.innerHTML = '';
                lastMessageId = 0;
            }

            input.disabled = true;

            try {
                await fetchJson(endpoints.send, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrf,
                    },
                    body: JSON.stringify({ body: text }),
                });

                chatStatus = 'open';
                closedDraftMode = false;
                input.value = '';
                await loadMessages(true);
            } catch (e) {
                alert(e.message || 'Не удалось отправить сообщение');
            } finally {
                input.disabled = false;
                input.focus();
            }
        });

        (async function init() {
            await refreshUnread();
            pollTimer = window.setInterval(function () {
                if (isOpen) {
                    if (chatStatus === 'closed' && closedDraftMode) {
                        return;
                    }
                    loadMessages(true);
                } else {
                    refreshUnread();
                }
            }, 2500);
        })();

        window.addEventListener('beforeunload', function () {
            if (pollTimer) {
                clearInterval(pollTimer);
            }
        });
    });
</script>
