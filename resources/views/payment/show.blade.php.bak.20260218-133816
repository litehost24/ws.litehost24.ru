    function attachNoteForm(form) {
        if (!form || form.dataset.noteBound) return;
        form.dataset.noteBound = '1';

        const noteWrap = form.closest('.service-block__note');
        const card = form.closest('.service-block__card');
        const noteView = noteWrap ? noteWrap.querySelector('.js-note-view') : null;
        const noteValue = noteWrap ? noteWrap.querySelector('.js-note-value') : null;
        const inlineStatus = noteWrap ? noteWrap.querySelector('.js-note-inline-status') : null;
        const editBtn = noteWrap ? noteWrap.querySelector('.js-note-edit-btn') : null;
        const cancelBtn = form.querySelector('.js-note-cancel-btn');
        const input = form.querySelector('input[name="note"]');
        const status = form.querySelector('.js-note-status');
        const submitBtn = form.querySelector('button[type="submit"]');
        const token = form.querySelector('input[name="_token"]');

        function setViewMode(isEdit) {
            if (noteView) {
                noteView.style.display = isEdit ? 'none' : '';
            }
            form.classList.toggle('--hidden', !isEdit);
            if (card) {
                card.classList.toggle('--note-editing', isEdit);
            }
            if (isEdit && input) {
                input.focus();
                input.select();
            }
        }

        function updateViewValue(rawNote) {
            const text = String(rawNote || '').trim();
            if (noteValue) {
                noteValue.textContent = text || 'Без пометки';
            }
            if (input) {
                input.value = text;
            }
            if (noteWrap) {
                noteWrap.classList.toggle('--empty', !text);
            }
        }

        updateViewValue(input ? input.value : (noteValue ? noteValue.textContent : ''));
        setViewMode(false);

        if (editBtn) {
            editBtn.addEventListener('click', function () {
                setViewMode(true);
            });
        }

        if (cancelBtn) {
            cancelBtn.addEventListener('click', function () {
                if (status) status.textContent = '';
                if (inlineStatus) inlineStatus.textContent = '';
                if (input && noteValue) {
                    input.value = noteValue.textContent === 'Без пометки' ? '' : noteValue.textContent;
                }
                setViewMode(false);
            });
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();

            if (status) status.textContent = 'Сохраняем...';
            if (submitBtn) submitBtn.disabled = true;

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-CSRF-TOKEN': token ? token.value : '',
                        'Accept': 'application/json',
                    },
                    body: new FormData(form),
                });

                const data = await response.json().catch(function () { return {}; });

                if (!response.ok) {
                    throw new Error(data.message || 'Ошибка сохранения');
                }

                updateViewValue(data.note);
                if (status) status.textContent = 'Сохранено';
                if (inlineStatus) inlineStatus.textContent = 'Сохранено';
                setViewMode(false);
                setTimeout(function () {
                    if (status && status.textContent === 'Сохранено') {
                        status.textContent = '';
                    }
                    if (inlineStatus && inlineStatus.textContent === 'Сохранено') {
                        inlineStatus.textContent = '';
                    }
                }, 1500);
            } catch (error) {
                if (inlineStatus) inlineStatus.textContent = '';
                if (status) status.textContent = error.message || 'Ошибка сохранения';
            } finally {
                if (submitBtn) submitBtn.disabled = false;
            }
        });
    }

    function attachNoteForms(root) {
        const scope = root || document;
        scope.querySelectorAll('.js-note-form').forEach(function (form) {
            attachNoteForm(form);
        });
    }

    function attachSubActionLink(link) {
        if (!link || link.dataset.subActionBound) return;
        link.dataset.subActionBound = '1';

        link.addEventListener('click', async function (event) {
            event.preventDefault();

            if (link.dataset.busy === '1') {
                return;
            }
            link.dataset.busy = '1';

            const confirmText = link.getAttribute('data-confirm');
            if (confirmText && !window.confirm(confirmText)) {
                link.dataset.busy = '';
                return;
            }

            link.classList.add('opacity-60');
            link.style.pointerEvents = 'none';
            const sourceCard = link.closest('.service-block__card');

            let action = link.dataset.action || '';
            if (!action) {
                try {
                    const url = new URL(link.href, window.location.origin);
                    action = url.searchParams.get('action') || '';
                } catch (e) {
                    action = '';
                }
            }
            if (action !== 'disable') {
                showOverlay('Подключаем подписку...');
            }

            try {
                const response = await fetch(link.href, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json',
                    },
