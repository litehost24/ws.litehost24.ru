                    }
                } else {
                    $actionOk = false;
                    $actionErrors[] = "?????? ?? ?????? (id={$parts[2]})";
                }
            } else {
                $actionOk = false;
                $actionErrors[] = "?? ??????? ?????????? server_id ?? file_path";
            }
        } else {
