            $parts = explode('_', $filename);

            if (isset($parts[2])) {
                $server = Server::where('id', $parts[2])->first();

                if ($server) {
                    if ($server->usesNode1Api()) {
                        try {
                            (new Node1Provisioner())->disableByName($server, $parts[1]);
                        } catch (\Exception $e) {
